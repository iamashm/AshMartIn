---
const links = [
  { href: '/writing', label: 'writing' },
  { href: '/projects', label: 'projects' },
  { href: '/about', label: 'about' },
];

const { pathname } = Astro.url;
---

<nav class="site-nav">
  <a href="/" class="nav-logo">ashmartin</a>
  <ul class="nav-links">
    {links.map(link => (
      <li>
        <a
          href={link.href}
          aria-current={pathname.startsWith(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
