---
interface Props {
  type?:  'note' | 'update' | 'warning';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const labels: Record<string, string> = {
  note:    title ?? 'Note',
  update:  title ?? 'Update',
  warning: title ?? 'Warning',
};
---

<aside class:list={['callout', `callout-${type}`]}>
  <span class="callout-label">{labels[type]}</span>
  <div class="callout-body"><slot /></div>
</aside>

<style>
  .callout {
    border-left: 2px solid var(--border);
    padding: 16px 20px;
    margin: 2.5em 0;
    border-radius: 0 4px 4px 0;
    background: var(--surface);
  }

  .callout-note    { border-left-color: var(--border); }
  .callout-update  { border-left-color: var(--accent); }
  .callout-warning { border-left-color: #e8a020; }

  .callout-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .callout-update  .callout-label { color: var(--accent); }
  .callout-warning .callout-label { color: #e8a020; }

  .callout-body {
    font-size: 15px;
    line-height: 1.7;
    color: var(--fg);
  }

  .callout-body :global(p:last-child) { margin-bottom: 0; }
  .callout-body :global(a) {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(43, 78, 255, 0.3);
  }
</style>
