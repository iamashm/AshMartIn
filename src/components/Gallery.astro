---
/**
 * Gallery — responsive image grid with lightbox.
 *
 * Usage:
 *   <Gallery images={[
 *     { src: '/images/project/shot-01.jpg', alt: 'Home view', caption: 'Default reading state' },
 *     ...
 *   ]} />
 */

interface GalleryImage {
  src:      string;
  alt:      string;
  caption?: string;
}

interface Props {
  images: GalleryImage[];
}

const { images } = Astro.props;
const id = `gallery-${Math.random().toString(36).slice(2, 8)}`;
---

<section class="gallery" data-gallery-id={id}>
  <p class="label" style="margin-bottom: 28px;">Gallery</p>

  <div class="gallery-grid">
    {images.map((img, i) => (
      <button
        class="gallery-item"
        data-index={i}
        aria-label={`Open image: ${img.alt}`}
        type="button"
      >
        <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
      </button>
    ))}
  </div>
</section>

<!-- Lightbox -->
<div class="lightbox-overlay" role="dialog" aria-modal="true" aria-label="Image viewer" hidden>
  <div class="lightbox-inner">
    <button class="lightbox-close" type="button" aria-label="Close">close ✕</button>

    <div class="lightbox-nav-arrows">
      <button class="lb-arrow lb-prev" type="button" aria-label="Previous image">←</button>
      <button class="lb-arrow lb-next" type="button" aria-label="Next image">→</button>
    </div>

    <div class="lightbox-img-wrap">
      <img class="lb-img" src="" alt="" />
    </div>
    <p class="lb-caption"></p>
  </div>
</div>

<style>
  /* ── Gallery grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
  }

  /* Span first and fifth item for rhythm */
  .gallery-item:nth-child(3n+1) { grid-column: span 2; }

  .gallery-item {
    display: block;
    background: var(--surface);
    overflow: hidden;
    cursor: zoom-in;
    border: none;
    padding: 0;
    position: relative;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 3;
    display: block;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s;
  }

  .gallery-item:nth-child(3n+1) img {
    aspect-ratio: 16 / 9;
  }

  .gallery-item:hover img {
    transform: scale(1.03);
    opacity: 0.88;
  }

  /* Expand icon on hover */
  .gallery-item::after {
    content: '↗';
    position: absolute;
    top: 10px;
    right: 10px;
    width: 26px;
    height: 26px;
    background: var(--bg);
    color: var(--fg);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }

  .gallery-item:hover::after { opacity: 1; }

  /* ── Lightbox */
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    cursor: zoom-out;
  }

  .lightbox-overlay[hidden] { display: none; }

  .lightbox-inner {
    position: relative;
    max-width: 1000px;
    width: 100%;
    cursor: default;
  }

  .lightbox-close {
    position: absolute;
    top: -40px;
    right: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.5);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 0;
    transition: color 0.2s;
  }

  .lightbox-close:hover { color: #fff; }

  .lightbox-nav-arrows {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: calc(100% + 88px);
    left: -44px;
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }

  .lb-arrow {
    pointer-events: all;
    background: none;
    border: none;
    color: rgba(255,255,255,0.4);
    font-size: 24px;
    cursor: pointer;
    padding: 16px 12px;
    transition: color 0.2s;
  }

  .lb-arrow:hover { color: #fff; }

  .lightbox-img-wrap { width: 100%; }

  .lb-img {
    width: 100%;
    max-height: 80vh;
    object-fit: contain;
    display: block;
  }

  .lb-caption {
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    min-height: 1em;
  }

  /* ── Mobile */
  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-item:nth-child(3n+1) { grid-column: span 1; }
    .gallery-item img { aspect-ratio: 4 / 3; }

    .lightbox-overlay { padding: 16px; }
    .lightbox-nav-arrows { width: calc(100% + 32px); left: -16px; }
    .lb-arrow { font-size: 20px; padding: 12px 8px; }
  }
</style>

<script define:vars={{ id, images }}>
  const section  = document.querySelector(`[data-gallery-id="${id}"]`);
  const overlay  = section?.nextElementSibling;
  if (!section || !overlay) return;

  const lbImg      = overlay.querySelector('.lb-img');
  const lbCaption  = overlay.querySelector('.lb-caption');
  const closeBtn   = overlay.querySelector('.lightbox-close');
  const prevBtn    = overlay.querySelector('.lb-prev');
  const nextBtn    = overlay.querySelector('.lb-next');

  let current = 0;

  function show(index) {
    current = (index + images.length) % images.length;
    const img = images[current];
    lbImg.src = img.src;
    lbImg.alt = img.alt;
    lbCaption.textContent = img.caption ?? '';
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function close() {
    overlay.hidden = true;
    document.body.style.overflow = '';
  }

  section.querySelectorAll('.gallery-item').forEach(btn => {
    btn.addEventListener('click', () => show(parseInt(btn.dataset.index, 10)));
  });

  closeBtn.addEventListener('click', close);
  prevBtn.addEventListener('click', () => show(current - 1));
  nextBtn.addEventListener('click', () => show(current + 1));

  overlay.addEventListener('click', e => { if (e.target === overlay) close(); });

  document.addEventListener('keydown', e => {
    if (overlay.hidden) return;
    if (e.key === 'Escape')      close();
    if (e.key === 'ArrowRight')  show(current + 1);
    if (e.key === 'ArrowLeft')   show(current - 1);
  });
</script>
